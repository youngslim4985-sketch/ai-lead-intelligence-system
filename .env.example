# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ANTHROPIC_API_KEY: Required for Claude AI message generation.
ANTHROPIC_API_KEY="sk-ant-XXXXXXXXXXXXXXXX"

# AIRTABLE_API_KEY: Personal Access Token for Airtable.
AIRTABLE_API_KEY="patXXXXXXXXXXXXXXXX"

# AIRTABLE_BASE_ID: The ID of your Airtable base.
AIRTABLE_BASE_ID="appXXXXXXXXXXXXXXXX"

# WEBHOOK_SECRET: Secret for HMAC validation of incoming leads.
WEBHOOK_SECRET="your-super-secret-key-here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
